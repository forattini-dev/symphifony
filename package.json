{
  "name": "fifony",
  "version": "0.1.11",
  "private": false,
  "type": "module",
  "description": "Filesystem-backed local Fifony orchestrator with a TypeScript CLI, MCP mode, and multi-agent Codex or Claude workflows.",
  "bin": {
    "fifony": "./bin/fifony.js"
  },
  "scripts": {
    "start": "node ./bin/fifony.js",
    "dev": "node ./bin/fifony.js --port 4000 --dev",
    "dev:api": "node ./bin/fifony.js --port 4000",
    "dev:ui": "vite --config src/dashboard/vite.config.js",
    "build": "tsup && vite build --config src/dashboard/vite.config.js",
    "build:server": "tsup",
    "build:ui": "vite build --config src/dashboard/vite.config.js",
    "prepublishOnly": "pnpm build",
    "mcp": "node ./bin/fifony.js mcp"
  },
  "files": [
    "bin/",
    "dist/",
    "src/dashboard/dist/",
    "src/dashboard/public/",
    "src/fixtures/",
    "README.md",
    "FIFONY.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forattini-dev/fifony.git"
  },
  "bugs": {
    "url": "https://github.com/forattini-dev/fifony/issues"
  },
  "homepage": "https://github.com/forattini-dev/fifony#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=23"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.3",
    "cli-args-parser": "^1.0.6",
    "lucide-react": "^0.577.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "raffel": "^1.0.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "s3db.js": "21.2.10",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.166.12",
    "@vitejs/plugin-react": "^6.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
